# Copy this file to .env before running docker compose:
#   cp .env.example .env
#
# On Linux, set AIRFLOW_UID to your host user id so mounted folders are writable:
#   echo "AIRFLOW_UID=$(id -u)" > .env

AIRFLOW_UID=50000
_PIP_ADDITIONAL_REQUIREMENTS=psycopg2-binary pandas apache-airflow-providers-postgres